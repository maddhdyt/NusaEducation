<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files/directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Append .html for paths that don't have an extension
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Fallback to index.html for 404s (optional, typically not needed if mapping works)
</IfModule>

<IfModule mod_mime.c>
  # Fix for next/font/local woff2 files in static export
  AddType application/font-woff2 .woff2
</IfModule>
